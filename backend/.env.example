# Backend environment variables
# Prefix is required: WARDROBE_

# Required for local default setup? No (falls back to sqlite file under backend/data/)
WARDROBE_DATABASE_URL=sqlite:///./data/wardrobe.db

# Optional: JSON list for FastAPI CORS origins.
# Keep this as valid JSON (including brackets and double quotes).
WARDROBE_CORS_ORIGINS=["https://your-frontend.vercel.app","http://localhost:3000","http://127.0.0.1:3000","http://localhost:5173","http://127.0.0.1:5173","null"]

# Optional: INFO | DEBUG | WARNING | ERROR
WARDROBE_LOG_LEVEL=INFO

# Storage backend: local | supabase
WARDROBE_STORAGE_BACKEND=local

# Required only when WARDROBE_STORAGE_BACKEND=supabase
WARDROBE_SUPABASE_URL=
WARDROBE_SUPABASE_ANON_KEY=
WARDROBE_SUPABASE_SERVICE_KEY=
WARDROBE_SUPABASE_JWT_SECRET=
WARDROBE_SUPABASE_BUCKET=wardrobe-images
WARDROBE_AUTH_REDIRECT_URL=http://127.0.0.1:8000/auth/callback

# Optional: enables Claude-based features (color analysis, reasoning, supervisor re-weighting)
WARDROBE_ANTHROPIC_API_KEY=

# Optional: enables weather enrichment via weatherapi.com
# Free plan is enough for temperature + condition + rain/snow chance.
WARDROBE_WEATHER_API_KEY=

# Optional model overrides
WARDROBE_AGENT_COLOR_MODEL=claude-sonnet-4-20250514
WARDROBE_AGENT_REASONING_MODEL=claude-haiku-4-5-20251001

# Color specialization controls
# anthropic_vision | fine_tuned | heuristic
WARDROBE_COLOR_AGENT_BACKEND=anthropic_vision
# Optional endpoint for your fine-tuned color classifier service
WARDROBE_COLOR_FINE_TUNED_ENDPOINT=
# Confidence gate for fallback handoff (0..1)
WARDROBE_COLOR_PROFILE_MIN_CONFIDENCE=0.65
# Enable secondary shadow evaluation for rollout comparison
WARDROBE_COLOR_AGENT_SHADOW_MODE=false

# Optional vector retrieval backend for scalable RAG (none | pinecone | azure_ai_search)
WARDROBE_VECTOR_STORE_BACKEND=none
WARDROBE_VECTOR_SEARCH_TOP_K=12
WARDROBE_VECTOR_EMBEDDING_PROVIDER=endpoint

# Embedding provider: endpoint (e.g. FastAPI/OpenAI-compatible) or huggingface
# endpoint: expects {"data":[{"embedding":[...]}]} or {"embedding":[...]}
WARDROBE_VECTOR_EMBEDDING_ENDPOINT=http://127.0.0.1:8000/v1/embeddings
WARDROBE_VECTOR_EMBEDDING_API_KEY=
WARDROBE_VECTOR_EMBEDDING_MODEL=local-hash-embedding-v1

# Hugging Face embedding settings (used when WARDROBE_VECTOR_EMBEDDING_PROVIDER=huggingface)
WARDROBE_HUGGINGFACE_EMBEDDING_API_KEY=
WARDROBE_HUGGINGFACE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Optional custom endpoint; defaults to https://api-inference.huggingface.co/models/{model}
WARDROBE_HUGGINGFACE_EMBEDDING_ENDPOINT=

# Pinecone settings
WARDROBE_PINECONE_API_KEY=
WARDROBE_PINECONE_INDEX_HOST=
WARDROBE_PINECONE_NAMESPACE=

# Azure AI Search settings
WARDROBE_AZURE_SEARCH_ENDPOINT=
WARDROBE_AZURE_SEARCH_API_KEY=
WARDROBE_AZURE_SEARCH_INDEX_NAME=
WARDROBE_AZURE_SEARCH_VECTOR_FIELD=content_vector
WARDROBE_AZURE_SEARCH_ITEM_ID_FIELD=item_id

# Hugging Face vision pipeline (async auto-tagging + background removal)
WARDROBE_VISION_ENABLED=false
WARDROBE_HF_API_TOKEN=
WARDROBE_HF_TAGGING_MODEL=openai/clip-vit-base-patch32
WARDROBE_HF_RMBG_MODEL=briaai/RMBG-1.4
WARDROBE_HF_TIMEOUT_SECONDS=20
WARDROBE_HF_MAX_RETRIES=2
